import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import seaborn as sns
from sklearn.ensemble import RandomForestRegressor
from sklearn.preprocessing import LabelEncoder


class House:

    def __init__(self, house_id, block, bedrooms, price, status="Available"):
        self.house_id = house_id
        self.block = block
        self.bedrooms = bedrooms
        self.price = price
        self.status = status  # Available, Sold, or Rented


class HousingEstate:

    def __init__(self, name):
        self.name = name
        self.properties = []
        self.model = RandomForestRegressor(n_estimators=100, random_state=42)
        self.label_encoder = LabelEncoder()
        self.is_trained = False

    def add_house(self, house):
        self.properties.append(house)

    def update_status(self, house_id, new_status):
        for house in self.properties:
            if house.house_id == house_id:
                house.status = new_status
                print(f"[INFO] House {house_id} updated to {new_status}.\n")
                return
        print("[ERROR] House ID not found.")

    def get_dataframe(self):
        """Converts internal property objects list into a clean Pandas DataFrame."""
        data = [vars(h) for h in self.properties]
        return pd.DataFrame(data)

    def display_estate(self):
        df = self.get_dataframe()
        print(f"\n--- {self.name} Status Report ---")
        print(df.to_string(index=False))
        print("-" * 45)

    def display_feature_importance(self):
        """Displays numerical feature weights and generates a Seaborn Barplot

        to visualize which structural characteristics influence pricing predictions most.
        """
        if not self.is_trained:
            print("[ERROR] Train the model first to analyze feature importance.")
            return

        importances = self.model.feature_importances_
        features = ["block", "bedrooms"]  # Clean names for presentation

        # Print out the console terminal text report
        print("\n--- Random Forest Feature Weights ---")
        for feature, importance in zip(features, importances):
            print(f" * {feature}: {importance * 100:.1f}%")
        print("-" * 37)

        # ---------------------------------------------------------------------
        # SEABORNE VISUALIZATION BARPLOT
        # ---------------------------------------------------------------------
        importance_df = pd.DataFrame({
            "Feature": features,
            "Importance (%)": importances * 100
        }).sort_values(by="Importance (%)", ascending=False)

        plt.figure(figsize=(8, 4))
        sns.barplot(
            data=importance_df,
            x="Importance (%)",
            y="Feature",
            hue="Feature",
            palette="viridis",
            legend=False
        )
        
        plt.title(f"Random Forest Feature Significance Matrix - {self.name}")
        plt.xlabel("Relative Influence Level (%)")
        plt.ylabel("Property Attribute")
        plt.xlim(0, 100)
        plt.grid(axis='x', linestyle="--", alpha=0.5)
        plt.tight_layout()
        plt.show()

    # -------------------------------------------------------------------------
    # NEW MACHINE LEARNING OPERATIONS
    # -------------------------------------------------------------------------
    def train_valuation_model(self):
        """Extracts data from properties marked as 'Sold' to train the Random

        Forest Regressor on market behavior.
        """
        df = self.get_dataframe()

        # Isolate historical data ('Sold') to train our baseline market patterns
        train_data = df[df["status"] == "Sold"].copy()

        if len(train_data) < 3:
            print(
                f"[WARN] Not enough historical sold records ({len(train_data)}) to train a reliable Random Forest. Need at least 3."
            )
            return False

        # Encode categorical 'block' data (e.g., 'Block A' -> 0, 'Block B' -> 1)
        self.label_encoder.fit(df["block"])
        train_data["block_encoded"] = self.label_encoder.transform(
            train_data["block"]
        )

        # Split features and pricing targets
        X = train_data[["block_encoded", "bedrooms"]]
        y = train_data["price"]

        # Fit the ensemble regressor
        print(
            f"[INFO] Optimizing Random Forest over {len(train_data)} sales records..."
        )
        self.model.fit(X, y)
        self.is_trained = True
        print("[SUCCESS] Valuation Engine trained successfully.")
        return True

    def predict_suggested_price(self, block, bedrooms):
        """Uses the optimized Random Forest to calculate a predicted market value

        for given features.
        """
        if not self.is_trained:
            print(
                "[ERROR] Machine Learning model has not been trained yet. Please log more transactions."
            )
            return None

        try:
            # Safely match block text to its trained mathematical code
            block_encoded = self.label_encoder.transform([block])[0]
        except ValueError:
            print(f"[ERROR] Block '{block}' was not found in trained dataset.")
            return None

        # Build feature vector query
        query_vector = pd.DataFrame(
            [[block_encoded, bedrooms]], columns=["block_encoded", "bedrooms"]
        )
        predicted_value = self.model.predict(query_vector)[0]
        return predicted_value


# --- Extended Demonstration ---
if __name__ == "__main__":
    # 1. Initialize Estate Database
    my_estate = HousingEstate("Greenwood Premium Estates")

    # 2. Populate with Historical "Sold" Records to establish market pricing patterns
    print("Populating historical sales history into database...")
    my_estate.add_house(House("H001", "Block A", 2, 190000, status="Sold"))
    my_estate.add_house(House("H002", "Block A", 3, 250000, status="Sold"))
    my_estate.add_house(House("H003", "Block A", 4, 310000, status="Sold"))
    my_estate.add_house(House("H004", "Block B", 2, 175000, status="Sold"))
    my_estate.add_house(House("H005", "Block B", 3, 220000, status="Sold"))
    my_estate.add_house(House("H006", "Block B", 4, 290000, status="Sold"))

    # 3. Add Live "Available" Houses awaiting evaluation
    my_estate.add_house(House("H101", "Block A", 3, 260000, status="Available"))
    my_estate.add_house(House("H102", "Block B", 4, 0, status="Available"))  # Unpriced house

    # Show initial layout
    my_estate.display_estate()

    # 4. Compile training datasets and optimize the Random Forest Regressor
    my_estate.train_valuation_model()

    # 5. Display numerical weights and launch the new Seaborne feature importance Barplot
    my_estate.display_feature_importance()

    # 6. Execute an intelligent prediction query
    print("\n" + "=" * 60)
    print(" RUNNING RANDOM FOREST MARKET EVALUATION INFERENCE")
    print("=" * 60)

    # Let's dynamically evaluate the optimal value for the unpriced house H102 (Block B, 4 bedrooms)
    target_block = "Block B"
    target_beds = 4

    suggested_valuation = my_estate.predict_suggested_price(
        target_block, target_beds
    )

    if suggested_valuation:
        print(
            f" Suggested Pricing Matrix for standard property ({target_block}, {target_beds} Beds):"
        )
        print(f" Predicted Market Value: € {suggested_valuation:,.2f}")
    print("=" * 60 + "\n")

    # Update asset with suggested machine learning valuation output
    my_estate.update_status("H102", "Available")
    for house in my_estate.properties:
        if house.house_id == "H102":
            house.price = int(suggested_valuation)

    # Show verified estate report
    my_estate.display_estate()
